function updatePlayerList()
    for _, v in pairs(TPScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    local count = 0
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            count = count + 1
            local b = Instance.new("TextButton", TPScroll)
            b.Size = UDim2.new(1, 0, 0, 32)
            b.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            b.BackgroundTransparency = 0.95
            b.Text = "  " .. p.DisplayName
            b.TextColor3 = Color3.fromRGB(200, 200, 205)
            b.Font = Enum.Font.GothamMedium
            b.TextSize = 11
            b.TextXAlignment = Enum.TextXAlignment.Left
            b.BorderSizePixel = 0
            Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
            
            b.MouseButton1Click:Connect(function()
                local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if hrp and myHrp then
                    myHrp.CFrame = hrp.CFrame * CFrame.new(0, 0, 3)
                    tween(b, {BackgroundTransparency = 0.7, TextColor3 = Color3.fromRGB(255, 127, 80)}, 0.1)
                    task.wait(0.1)
                    tween(b, {BackgroundTransparency = 0.95, TextColor3 = Color3.fromRGB(200, 200, 205)}, 0.2)
                end
            end)
        end
    end
    TPScroll.CanvasSize = UDim2.new(0, 0, 0, count * 36)
end

