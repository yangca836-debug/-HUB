-- [ Logic: Role Detection ] --
local function getRole(p)
    if not p or not p.Character then return "Innocent" end
    local backpack = p:FindFirstChild("Backpack")
    local char = p.Character
    local knife = char:FindFirstChild("Knife") or (backpack and backpack:FindFirstChild("Knife"))
    local gun = char:FindFirstChild("Gun") or (backpack and backpack:FindFirstChild("Gun"))
    if knife then return "Murderer" end
    if gun then return "Sheriff" end
    return "Innocent"
end

-- [ Logic: Auto Coin ] --
local bv, bg
RunService.Heartbeat:Connect(function()
    if not RUNNING then return end
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if _G.AUTO_COIN and hrp then
        if not bv then bv = Instance.new("BodyVelocity", hrp); bv.MaxForce = Vector3.new(1e6, 1e6, 1e6) end
        if not bg then bg = Instance.new("BodyGyro", hrp); bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6) end
        
        local targetCoin = nil
        local dist = _G.DETECTION_RANGE
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and (v.Name:find("Coin") or v:FindFirstChild("CoinVisual")) and v.Transparency < 1 then
                local d = (hrp.Position - v.Position).Magnitude
                if d < dist then dist = d; targetCoin = v end
            end
        end
        
        if targetCoin then
            bv.Velocity = (targetCoin.Position + Vector3.new(0, _G.HEIGHT, 0) - hrp.Position).Unit * _G.SPEED
            bg.CFrame = CFrame.new(hrp.Position, targetCoin.Position)
            if (hrp.Position - targetCoin.Position).Magnitude < _G.COLLECT_DISTANCE then
                firetouchinterest(hrp, targetCoin, 0); firetouchinterest(hrp, targetCoin, 1)
            end
        else
            bv.Velocity = Vector3.zero
        end
    else
        if bv then bv:Destroy() bv = nil end
        if bg then bg:Destroy() bg = nil end
    end
end)

-- [ Logic: ESP & Aimbot ] --
RunService.RenderStepped:Connect(function()
    if not RUNNING then return end
    local murdChar = nil
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local role = getRole(p)
            local hl = p.Character:FindFirstChild("Pro_HL")
            if _G.ESP_ENABLED then
                if not hl then 
                    hl = Instance.new("Highlight", p.Character); hl.Name = "Pro_HL" 
                    hl.OutlineTransparency = 0.2; hl.FillTransparency = 0.5
                end
                hl.FillColor = RoleColors[role]
                hl.OutlineColor = RoleColors[role]
            elseif hl then hl:Destroy() end
            if role == "Murderer" then murdChar = p.Character end
        end
    end
    
    if _G.AIM_ENABLED and murdChar and murdChar:FindFirstChild("HumanoidRootPart") then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, murdChar.HumanoidRootPart.Position)
    end
end)

-- [ Draggable Setup ] --
local function makeDraggable(obj, header)
    local dragging, input, startPos, startInput
    header.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; startInput = i.Position; startPos = obj.Position end end)
    UIS.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then 
        local delta = i.Position - startInput
        obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
end

