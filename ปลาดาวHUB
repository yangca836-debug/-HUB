local function createToggle(name, default, callback, order)
    local Btn = Instance.new("TextButton", Scroll)
    Btn.Size = UDim2.new(1, -20, 0, 34)
    Btn.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    Btn.Text = "  " .. name
    Btn.TextColor3 = Color3.fromRGB(230, 230, 230)
    Btn.Font = Enum.Font.GothamSemibold
    Btn.TextSize = 10
    Btn.TextXAlignment = Enum.TextXAlignment.Left
    Btn.LayoutOrder = order
    Btn.BorderSizePixel = 0
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 8)
    
    local Sw = Instance.new("Frame", Btn)
    Sw.Size = UDim2.new(0, 30, 0, 14)
    Sw.Position = UDim2.new(1, -40, 0.5, -7)
    Sw.BackgroundColor3 = default and Color3.fromRGB(255, 110, 50) or Color3.fromRGB(45, 45, 50)
    Instance.new("UICorner", Sw).CornerRadius = UDim.new(1, 0)

    local Circle = Instance.new("Frame", Sw)
    Circle.Size = UDim2.new(0, 10, 0, 10)
    Circle.Position = default and UDim2.new(1, -12, 0.5, -5) or UDim2.new(0, 2, 0.5, -5)
    Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)
    
    local state = default
    Btn.MouseButton1Click:Connect(function()
        if isUILocked then return end
        state = not state
        callback(state)
        tween(Sw, {BackgroundColor3 = state and Color3.fromRGB(255, 110, 50) or Color3.fromRGB(45, 45, 50)})
        tween(Circle, {Position = state and UDim2.new(1, -12, 0.5, -5) or UDim2.new(0, 2, 0.5, -5)})
    end)
end

local function createSlider(name, min, max, default, callback, order)
    local Frame = Instance.new("Frame", Scroll)
    Frame.Size = UDim2.new(1, -20, 0, 48)
    Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    Frame.LayoutOrder = order
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 8)
    
    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(1, -20, 0, 20)
    Label.Position = UDim2.new(0, 10, 0, 4)
    Label.Text = name .. " : " .. tostring(default)
    Label.TextColor3 = Color3.fromRGB(230, 230, 230)
    Label.Font = Enum.Font.GothamSemibold
    Label.TextSize = 9
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.BackgroundTransparency = 1

    local SliderBg = Instance.new("Frame", Frame)
    SliderBg.Size = UDim2.new(1, -20, 0, 4)
    SliderBg.Position = UDim2.new(0, 10, 0, 32)
    SliderBg.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    Instance.new("UICorner", SliderBg).CornerRadius = UDim.new(1, 0)

    local Fill = Instance.new("Frame", SliderBg)
    Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    Fill.BackgroundColor3 = Color3.fromRGB(255, 110, 50)
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)
    
    local Btn = Instance.new("TextButton", SliderBg)
    Btn.Size = UDim2.new(1, 0, 1, 15)
    Btn.Position = UDim2.new(0, 0, 0.5, -7)
    Btn.BackgroundTransparency = 1
    Btn.Text = ""

    local dragging = false
    local inputObj = nil

    Btn.InputBegan:Connect(function(input)
        if isUILocked then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; inputObj = input; Scroll.ScrollingEnabled = false
        end
    end)
    UIS.InputEnded:Connect(function(input) if input == inputObj then dragging = false; inputObj = nil; Scroll.ScrollingEnabled = true end end)
    
    RunService.RenderStepped:Connect(function()
        if dragging and inputObj and not isUILocked then
            local pos = math.clamp((inputObj.Position.X - SliderBg.AbsolutePosition.X) / SliderBg.AbsoluteSize.X, 0, 1)
            local value = math.floor(min + ((max - min) * pos))
            Fill.Size = UDim2.new(pos, 0, 1, 0)
            Label.Text = name .. " : " .. tostring(value)
            callback(value)
        end
    end)
end

