local function getRole(p)
    if not p or not p.Character then return "Innocent" end
    local char = p.Character; local backpack = p:FindFirstChild("Backpack")
    local knife = char:FindFirstChild("Knife") or char:FindFirstChild("Dagger") or (backpack and (backpack:FindFirstChild("Knife") or backpack:FindFirstChild("Dagger")))
    local gun = char:FindFirstChild("Gun") or char:FindFirstChild("Revolver") or (backpack and (backpack:FindFirstChild("Gun") or backpack:FindFirstChild("Revolver")))
    if knife then return "Murderer" end
    if gun then return "Sheriff" end
    return "Innocent"
end

local function getClosestCoin(hrp)
    local closest, dist = nil, _G.DETECTION_RANGE
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name:find("Coin") or v:FindFirstChild("CoinVisual")) and v.Transparency < 1 then
            local d = (hrp.Position - v.Position).Magnitude
            if d < dist then dist = d; closest = v end
        end
    end
    return closest
end

local bv, bg
local function handleAutoCoin(myChar, myHrp)
    if not _G.AUTO_COIN then
        if bv then bv:Destroy(); bv = nil end
        if bg then bg:Destroy(); bg = nil end
        return
    end
    if not bv then bv = Instance.new("BodyVelocity", myHrp); bv.MaxForce = Vector3.new(1e6, 1e6, 1e6) end
    if not bg then bg = Instance.new("BodyGyro", myHrp); bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6); bg.P = 10000 end
    
    for _, v in pairs(myChar:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
    
    local coin = getClosestCoin(myHrp)
    if coin then
        local target = coin.Position + Vector3.new(0, _G.HEIGHT, 0)
        bv.Velocity = (target - myHrp.Position).Unit * _G.SPEED
        bg.CFrame = CFrame.new(myHrp.Position, coin.Position)
        pcall(function() firetouchinterest(myHrp, coin, 0); firetouchinterest(myHrp, coin, 1) end)
    else 
        bv.Velocity = Vector3.zero 
    end
end

RunService.RenderStepped:Connect(function()
    if not RUNNING then return end
    local myChar = LocalPlayer.Character
    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local targetMurd = nil
    
    for _, p in pairs(Players:GetPlayers()) do
        pcall(function()
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local char = p.Character; local role = getRole(p)
                
                -- ESP
                local hl = char:FindFirstChild("SF_Visual")
                if _G.ESP_ENABLED then
                    if not hl then hl = Instance.new("Highlight", char); hl.Name = "SF_Visual" end
                    hl.FillColor = RoleColors[role]; hl.OutlineColor = RoleColors[role]
                elseif hl then hl:Destroy() end
                
                -- Avatar Icon
                local head = char:FindFirstChild("Head")
                if head then
                    local icon = head:FindFirstChild("StarIcon")
                    if _G.AVATAR_ENABLED then
                        if not icon then
                            icon = Instance.new("BillboardGui", head); icon.Name = "StarIcon"
                            icon.Size = UDim2.new(0, 30, 0, 30); icon.StudsOffset = Vector3.new(0, 3, 0); icon.AlwaysOnTop = true
                            local img = Instance.new("ImageLabel", icon); img.Size = UDim2.new(1,0,1,0); img.BackgroundTransparency = 1
                            img.Image = "rbxthumb://type=AvatarHeadShot&id="..p.UserId.."&w=150&h=150"
                            Instance.new("UICorner", img).CornerRadius = UDim.new(1,0)
                            local st = Instance.new("UIStroke", img); st.Thickness = 2; st.Name = "St"
                        end
                        icon.ImageLabel.St.Color = RoleColors[role]
                    elseif icon then icon:Destroy() end
                end

                if role == "Murderer" then targetMurd = char end
            end
        end)
    end
    
    -- Aimbot
    if _G.AIM_ENABLED and targetMurd and myChar and (myChar:FindFirstChild("Gun") or myChar:FindFirstChild("Revolver")) then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetMurd.HumanoidRootPart.Position)
    end
    
    -- [ AUTO COIN LOGIC ] --
    if myHrp then handleAutoCoin(myChar, myHrp) end
end)

-- Fling Logic
RunService.Heartbeat:Connect(function()
    if RUNNING and _G.FLING_ACTIVE and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local root = LocalPlayer.Character.HumanoidRootPart
        local oldV = root.Velocity
        root.Velocity = Vector3.new(_G.FLING_POWER, _G.FLING_POWER, _G.FLING_POWER)
        RunService.RenderStepped:Wait()
        root.Velocity = oldV
    end
end)

-- Drag System
local function makeDraggable(obj, header)
    local activeDragInput = nil; local startPos; local dragStart
    header.InputBegan:Connect(function(i) if not isUILocked and (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) then activeDragInput = i; dragStart = i.Position; startPos = obj.Position end end)
    UIS.InputChanged:Connect(function(i) if i == activeDragInput then local d = i.Position - dragStart; obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y) end end)
    UIS.InputEnded:Connect(function(i) if i == activeDragInput then activeDragInput = nil end end)
end
