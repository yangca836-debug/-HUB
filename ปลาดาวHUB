            local Icon = Instance.new("TextLabel", Btn)
            Icon.Size = UDim2.new(0, 34, 0, 34)
            Icon.Position = UDim2.new(0, 5, 0.5, -17)
            Icon.BackgroundColor3 = Color3.fromRGB(30, 60, 100)
            Icon.Text = string.upper(string.sub(player.Name, 1, 1))
            Icon.TextColor3 = Color3.fromRGB(80, 200, 255)
            Icon.TextSize = 16
            Icon.Font = Enum.Font.GothamBold
            Icon.BorderSizePixel = 0
            Instance.new("UICorner", Icon).CornerRadius = UDim.new(0, 17)

            local NameLabel = Instance.new("TextLabel", Btn)
            NameLabel.Size = UDim2.new(1, -55, 0, 22)
            NameLabel.Position = UDim2.new(0, 48, 0, 7)
            NameLabel.BackgroundTransparency = 1
            NameLabel.Text = player.Name
            NameLabel.TextColor3 = Color3.fromRGB(220, 220, 255)
            NameLabel.TextSize = 13
            NameLabel.Font = Enum.Font.GothamBold
            NameLabel.TextXAlignment = Enum.TextXAlignment.Left

            local DisplayLabel = Instance.new("TextLabel", Btn)
            DisplayLabel.Size = UDim2.new(1, -55, 0, 16)
            DisplayLabel.Position = UDim2.new(0, 48, 0, 25)
            DisplayLabel.BackgroundTransparency = 1
            DisplayLabel.Text = player.DisplayName
            DisplayLabel.TextColor3 = Color3.fromRGB(100, 130, 180)
            DisplayLabel.TextSize = 11
            DisplayLabel.Font = Enum.Font.Gotham
            DisplayLabel.TextXAlignment = Enum.TextXAlignment.Left

            local SelIndicator = Instance.new("Frame", Btn)
            SelIndicator.Size = UDim2.new(0, 3, 0.6, 0)
            SelIndicator.Position = UDim2.new(1, -8, 0.2, 0)
            SelIndicator.BackgroundColor3 = Color3.fromRGB(80, 200, 255)
            SelIndicator.BorderSizePixel = 0
            SelIndicator.Visible = false
            Instance.new("UICorner", SelIndicator).CornerRadius = UDim.new(1, 0)

            local thisPlayer = player
            Btn.MouseButton1Click:Connect(function()
                for _, b in pairs(playerButtons) do
                    b.BackgroundColor3 = Color3.fromRGB(20, 25, 40)
                    local ind = b:FindFirstChildWhichIsA("Frame")
                    if ind then ind.Visible = false end
                end
                selectedPlayer = thisPlayer
                Btn.BackgroundColor3 = Color3.fromRGB(20, 50, 90)
                SelIndicator.Visible = true
                StatusLabel.Text = "✅ เลือก: " .. thisPlayer.Name
                StatusLabel.TextColor3 = Color3.fromRGB(80, 220, 120)
            end)

            Btn.MouseEnter:Connect(function()
                if selectedPlayer ~= thisPlayer then
                    tween(Btn, {BackgroundColor3 = Color3.fromRGB(25, 35, 55)}, 0.15)
                end
            end)
            Btn.MouseLeave:Connect(function()
                if selectedPlayer ~= thisPlayer then
                    tween(Btn, {BackgroundColor3 = Color3.fromRGB(20, 25, 40)}, 0.15)
                end
            end)

            table.insert(playerButtons, Btn)
            ySize = ySize + 50
        end
    end
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, ySize)
end

-- ====== Teleport Action ======
TeleportBtn.MouseButton1Click:Connect(function()
    if not selectedPlayer then
        StatusLabel.Text = "⚠️ กรุณาเลือกผู้เล่นก่อน!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 160, 60)
        return
    end
    local targetChar = selectedPlayer.Character
    if not targetChar then
        StatusLabel.Text = "❌ ผู้เล่นยังไม่มี Character"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetRoot then
        StatusLabel.Text = "❌ ไม่พบตำแหน่งผู้เล่น"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    local offset = targetRoot.CFrame.LookVector * 5
    local newCFrame = CFrame.new(targetRoot.Position + offset) * CFrame.Angles(0, math.pi, 0)
    myRoot.CFrame = newCFrame

    StatusLabel.Text = "🚀 Teleport สำเร็จ! ไปหา " .. selectedPlayer.Name
    StatusLabel.TextColor3 = Color3.fromRGB(80, 255, 160)
    tween(TeleportBtn, {BackgroundColor3 = Color3.fromRGB(40, 200, 100)}, 0.1)
    task.wait(0.3)
    tween(TeleportBtn, {BackgroundColor3 = Color3.fromRGB(30, 120, 220)}, 0.2)
end)

TeleportBtn.MouseEnter:Connect(function()
    tween(TeleportBtn, {BackgroundColor3 = Color3.fromRGB(50, 150, 255)}, 0.15)
end)
TeleportBtn.MouseLeave:Connect(function()
